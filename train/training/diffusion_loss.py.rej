+    if schedule == "seva_ddpm":
+        if objective != "epsilon":
+            raise ValueError(
+                "schedule='seva_ddpm' trains the raw SEVA wrapper as epsilon prediction. "
+                f"Use objective='epsilon', got {objective!r}."
+            )
+
+        timesteps, sigma, _denoiser = sample_seva_noise_levels(
+            (B, T),
+            device=device_obj,
+            num_idx=1000,
+            same_noise_level_per_clip=True,
+        )
+        sigma_e = _expand_bt(sigma, latents)
+
+        # Match the released SEVA denoiser convention:
+        #   x_sigma = x0 + sigma * eps
+        #   network input = x_sigma * c_in, where c_in = 1 / sqrt(sigma^2 + 1)
+        noisy_latents = latents + sigma_e * noise
+        alpha = torch.ones_like(sigma)
+        target = noise
+
+        x = noisy_latents.flatten(0, 1)
+        target_flat = target.flatten(0, 1)
+
+        # SGMWrapper does not consume "replace"; the released DiscreteDenoiser
+        # applies it before calling the network, so do the same here.
+        replace = moved_c.pop("replace", None)
+        if replace is not None:
+            replace_x, replace_mask = replace.split((x.shape[1], 1), dim=1)
+            replace_x = replace_x.to(device=device_obj, dtype=x.dtype)
+            replace_mask = replace_mask.to(device=device_obj, dtype=x.dtype)
+            x = x * (1.0 - replace_mask) + replace_x * replace_mask
+
+        sigma_flat = sigma.flatten(0, 1).to(device=device_obj, dtype=x.dtype)
+        c_in = torch.rsqrt(sigma_flat[:, None, None, None].square() + 1.0)
